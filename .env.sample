# Copy to .env and edit values as needed. Used by docker-compose variable substitution.
# Image (pulled from GHCR — see .github/workflows/docker-multiarch.yml)
# Example: ghcr.io/mahmuterkanyesil/subsync:latest
#IMAGE=ghcr.io/mahmuterkanyesil/subsync:latest

# Paths
DATA_DIR=./data
TV_DIR=/path/to/tv
MOVIES_DIR=/path/to/movies

# Service settings
WATCH_DIRS=/tv:/movies
SCAN_INTERVAL_SEC=30
EMBED_INTERVAL_SEC=600
BATCH_SIZE=500
WORKER_CONCURRENCY=2
LOG_LEVEL=info

# Redis (default compose uses internal redis)
#REDIS_URL=redis://redis:6379/0

# Log forwarding (API internal endpoint)
LOG_FORWARD_URL=http://api:8080/api/internal/logs
